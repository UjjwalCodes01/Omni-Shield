# Omni-Shield XCM Relayer Configuration
# Copy to .env and fill in values

# =========================================================================
# EVM / Polkadot Hub
# =========================================================================
RPC_URL=https://eth-rpc-testnet.polkadot.io/
CHAIN_ID=420420417

# Relayer private key (KEEP SECRET — this account pays gas)
RELAYER_PRIVATE_KEY=

# =========================================================================
# Contract Addresses (set after deployment)
# =========================================================================
XCM_ROUTER_ADDRESS=
YIELD_ROUTER_ADDRESS=
ESCROW_ADDRESS=
STEALTH_PAYMENT_ADDRESS=
HUB_ADDRESS=

# =========================================================================
# Relayer Settings
# =========================================================================
# Polling interval in milliseconds (default: 6000 = 6s)
POLL_INTERVAL_MS=6000

# Max retries for failed transactions
MAX_TX_RETRIES=3

# Gas price multiplier (1.2 = 20% above estimate)
GAS_PRICE_MULTIPLIER=1.2

# Confirmation blocks to wait before confirming dispatch
CONFIRMATION_BLOCKS=2

# Log level: error, warn, info, debug
LOG_LEVEL=info

# =============================================================================
# Omni-Shield Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to source control!
#
# Setup Guide:
#   1. cp .env.example .env
#   2. Fill in all values below
#   3. Fund your deployer with PAS tokens from:
#      https://faucet.polkadot.io (Select: Paseo -> AssetHub)
# =============================================================================

# -----------------------------------------------------------------------------
# Wallet Keys
# -----------------------------------------------------------------------------
# Generate with: cast wallet new
# Remove the 0x prefix from the private key

# Deployer wallet — deploys & owns all contracts (WITH 0x prefix)
DEPLOYER_PRIVATE_KEY=0x

# Fee collector — separate wallet that receives protocol fees
# (Use a DIFFERENT wallet than deployer to track fee income)
FEE_COLLECTOR=

# -----------------------------------------------------------------------------
# RPC Endpoints
# -----------------------------------------------------------------------------
# Polkadot Hub (Westend Asset Hub) — EVM-compatible via pallet-revive
# Default public endpoint (rate limited):
POLKADOT_HUB_TESTNET_RPC=https://westend-asset-hub-eth-rpc.polkadot.io

# Mainnet — leave empty until launch
POLKADOT_HUB_MAINNET_RPC=

# -----------------------------------------------------------------------------
# Explorer / Verification
# -----------------------------------------------------------------------------
# For contract verification on Blockscout:
#   1. Go to the Polkadot Hub Blockscout Explorer
#   2. Sign in → My Account → API Keys → Add New Key
EXPLORER_API_KEY=

# -----------------------------------------------------------------------------
# Protocol Configuration
# -----------------------------------------------------------------------------
# Protocol fee in basis points (100 bps = 1%, max 500 bps = 5%)
PROTOCOL_FEE_BPS=50

# Minimum deposit for Yield Router (in wei, 0.01 ether = 10000000000000000)
MIN_DEPOSIT=10000000000000000

# Oracle address for yield rate updates (defaults to deployer on testnet)
ORACLE_ADDRESS=
